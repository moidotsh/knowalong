# Arqavellum environment variables.
# Copy this file to `.env.local` and fill in the values for your
# Supabase project. Arqavellum needs URL + anon key — that's it. Consumers
# add domain-specific env vars as needed.
#
# Find these in your Supabase dashboard:
#   Project Settings → API → Project URL
#   Project Settings → API → Project API keys → anon public

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
