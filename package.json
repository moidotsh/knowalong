{
  "name": "knowalong",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "KnowAlong — private language-learning tool that turns user-pasted media text into structured study material and flashcards.",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "vercel-build": "TAMAGUI_TARGET=web EXPO_NO_DOTENV=1 expo export --platform web --output-dir dist --max-workers=1",
    "lint": "eslint .",
    "lint:structure": "bun run scripts/audit-barrels.ts && bun run scripts/audit-data-layer.ts && bun run scripts/audit-state.ts && bun run scripts/audit-security.ts && bun run scripts/audit-logging-errors.ts && bun run scripts/audit-ui-theme.ts && bun run scripts/audit-component-quality.ts && bun run scripts/audit-testing-types.ts && bun run scripts/audit-pattern-compliance.ts && bun run scripts/audit-runtime-resilience.ts && bun run scripts/audit-screen-body.ts && bun run scripts/audit-mobile-content-width.ts && eslint . --config eslint.structure.config.js --quiet",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:web": "expo export --platform web --max-workers=1",
    "verify:web-build": "bun run scripts/verify-web-build.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "^12.0.1",
    "@supabase/supabase-js": "^2.79.0",
    "@tamagui/adapt": "2.3.0",
    "@tamagui/animations-reanimated": "2.3.0",
    "@tamagui/babel-plugin": "2.3.0",
    "@tamagui/button": "2.3.0",
    "@tamagui/config": "2.3.0",
    "@tamagui/core": "2.3.0",
    "@tamagui/font-inter": "2.3.0",
    "@tamagui/lucide-icons-2": "2.3.0",
    "@tamagui/native": "2.3.0",
    "@tamagui/select": "2.3.0",
    "@tamagui/sheet": "2.3.0",
    "@tamagui/shorthands": "2.3.0",
    "@tamagui/themes": "2.3.0",
    "@tamagui/web": "2.3.0",
    "@tanstack/react-query": "^5.90.21",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "date-fns": "^4.1.0",
    "expo": "~54.0.35",
    "expo-clipboard": "^56.0.4",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-haptics": "^15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^3.0.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tamagui": "2.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-inline-import": "^3.0.0",
    "bun-types": "^1.2.13",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "@tamagui/core": "2.3.0",
    "@tamagui/lucide-icons-2": "2.3.0",
    "@tamagui/web": "2.3.0",
    "tamagui": "2.3.0"
  },
  "private": true
}
